{
  "family": "backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::476003490631:role/LabRole",
  "taskRoleArn": "arn:aws:iam::476003490631:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend-task",
      "image": "476003490631.dkr.ecr.us-east-1.amazonaws.com/carpultec-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "SPRING_JPA_HIBERNATE_DDL_AUTO",
          "value": "update"
        },
        {
          "name": "JAVA_OPTS",
          "value": "-XX:MaxRAMPercentage=75"
        },
        {
          "name": "GOOGLE_MAPS_BASE_URL",
          "value": "https://maps.googleapis.com/maps/api"
        },
        {
          "name": "APP_JWT_EXPIRATION_MS",
          "value": "86400000"
        },
        {
          "name": "APP_JWT_REFRESH_EXPIRATION_MS",
          "value": "604800000"
        }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/spring-datasource-url"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/spring-datasource-username"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/spring-datasource-password"
        },
        {
          "name": "GOOGLE_MAPS_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/google-maps-api-key"
        },
        {
          "name": "APP_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/jwt-secret"
        },
        {
          "name": "APP_MAIL_FROM",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/mail-from"
        },
        {
          "name": "CORS_ORIGINS",
          "valueFrom": "arn:aws:ssm:us-east-1:476003490631:parameter/carpultec/prod/cors-origins"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:8080/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}